# === Database (Supabase Postgres) ===
# Pooler (PgBouncer) — untuk runtime aplikasi / Prisma Client
# Contoh bentuk (isi dengan nilai dari Supabase Dashboard → Database → Connection string):
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Koneksi langsung (tanpa pooler) — wajib untuk `prisma migrate` / operasi yang tidak kompatibel dengan PgBouncer
# Contoh: port 5432, host sama atau "direct" connection string dari Supabase
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# === Auth API (JWT) ===
JWT_SECRET="generate-a-long-random-string"

# Same secret as Next.js NEXTAUTH_SECRET — used to verify Bearer tokens from the web app
NEXTAUTH_SECRET="generate-a-long-random-string"

# === Permify (ReBAC) — optional in dev: PERMIFY_DISABLED=true ===
PERMIFY_DISABLED=true
PERMIFY_BASE_URL=http://127.0.0.1:3476
PERMIFY_TENANT_ID=t1

# === BullMQ (optional) ===
# If REDIS_URL is set but START_EMAIL_WORKER is not true, emails are sent via Brevo
# immediately from the API process (not queued). Enable worker only if you run a
# dedicated worker that processes the queue.
REDIS_URL=
# START_EMAIL_WORKER=true

# Brevo transactional email (https://app.brevo.com/settings/keys/api)
BREVO_API_KEY=
# Exact "From" address + name from Brevo → Senders, domains & dedicated IPs → Senders (verified sender)
BREVO_SENDER_EMAIL=your-verified-sender@example.com
BREVO_SENDER_NAME=Ecosystra

APP_BASE_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:3002

# === Pusher (opsional) ===
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="ap1"

# === Opsional ===
CLICKHOUSE_URL="http://localhost:8123"

# === Server ===
PORT=4000
