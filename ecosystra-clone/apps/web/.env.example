# GraphQL API (ecosystra-clone/apps/api)
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

# NextAuth — use the same NEXTAUTH_SECRET as the API for JWT verification
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=generate-a-long-random-string-min-32-chars

# Google OAuth (same project as Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public client id (optional; falls back in auth-options)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Brevo (SMS / email OTP) — get a key from https://app.brevo.com/settings/keys/api
VITE_BREVO_API_KEY=
