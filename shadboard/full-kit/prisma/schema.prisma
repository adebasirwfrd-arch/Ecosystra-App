datasource db {
  provider = "postgresql"
  // Prisma CLI (`db push`, `migrate`) reads `DATABASE_URL` only.
  //
  // Supabase (pick one for this var):
  // - **Direct** `db.<project>.supabase.co:5432` — lowest latency when reachable (dev laptop / same-region VPS).
  // - **Transaction pooler** `…pooler.supabase.com:6543?pgbouncer=true&connection_limit=1` — when :5432 is blocked
  //   or for serverless; `src/lib/prisma.ts` may still prefer `DIRECT_URL` at runtime unless `PRISMA_USE_POOLER=true`.
  // - **Session pooler** (Dashboard → Connect → “Session mode”) — port 5432 on the pooler host; use Prisma’s
  //   `?pgbouncer=true` only for transaction mode :6543, not for session pooler unless Supabase docs say otherwise.
  url     = env("DATABASE_URL")
  schemas = ["nextauth", "shadboard_content", "public"]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  // Isolated from node_modules/@prisma/client so stale generates cannot break EcoEmail fields (cc, bcc, attachments).
  output          = "../src/generated/prisma"
}

model User {
  id                   String          @id @default(uuid())
  name                 String
  username             String?         @unique
  email                String?         @unique
  emailVerifyToken     String?
  emailVerified        DateTime?
  password             String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  image                String?
  avatar               String?
  profileBackground    String?
  status               String          @default("ONLINE")
  preferences          UserPreference?
  accounts             Account[]
  sessions             Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name, username, status, createdAt])
  @@schema("nextauth")
}

model UserPreference {
  id        String  @id @default(uuid())
  theme     String
  mode      String
  radius    String
  layout    String
  direction String
  user      User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String? @unique

  @@schema("nextauth")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@schema("nextauth")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("nextauth")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@schema("nextauth")
}

// Serialized page/module UI state (JSON document per module: email, chat, calendar).
model ShadboardPageContent {
  id        String   @id @default(uuid())
  module    String   @unique
  payload   Json
  updatedAt DateTime @updatedAt

  @@map("shadboard_page_content")
  @@schema("shadboard_content")
}

// ============================================================
// Ecosystra domain models (schema: public)
// ============================================================

model EcoWorkspace {
  id                 String                  @id @default(uuid())
  name               String
  description        String?
  folders            EcoFolder[]
  boards             EcoBoard[]
  members            EcoMember[]
  taskAssigneeInvites EcoTaskAssigneeInvite[]
  createdAt          DateTime                @default(now())

  @@map("Workspace")
  @@schema("public")
}

model EcoFolder {
  id          String       @id @default(uuid())
  name        String
  workspaceId String
  workspace   EcoWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  boards      EcoBoard[]

  @@map("Folder")
  @@schema("public")
}

model EcoBoard {
  id              String       @id @default(uuid())
  name            String
  workspaceId     String
  workspace       EcoWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folderId        String?
  folder          EcoFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdBy       EcoUser?     @relation("BoardCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  columns         Json         @default("[]")
  subitemColumns  Json         @default("[]")
  groups          EcoGroup[]
  items           EcoItem[]
  createdAt       DateTime     @default(now())

  @@map("Board")
  @@schema("public")
}

model EcoGroup {
  id      String   @id @default(uuid())
  name    String
  color   String?
  boardId String
  board   EcoBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  items   EcoItem[]

  @@map("Group")
  @@schema("public")
}

model EcoItem {
  id              String          @id @default(uuid())
  name            String
  boardId         String
  board           EcoBoard        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  groupId         String?
  group           EcoGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdBy       EcoUser?  @relation("ItemCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  parentItemId    String?
  parentItem      EcoItem?  @relation("ItemToSubitems", fields: [parentItemId], references: [id])
  subitems        EcoItem[] @relation("ItemToSubitems")
  dynamicData     Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  auditLogs       EcoTaskAuditLog[]
  chatThreads     EcoChatThread[]
  assigneeInvites EcoTaskAssigneeInvite[]

  @@map("Item")
  @@schema("public")
}

/// Pending email invites for task assignees (Brevo). Accept flow adds user to workspace + assignees.
model EcoTaskAssigneeInvite {
  id              String         @id @default(uuid())
  itemId          String
  item            EcoItem        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  email           String
  token           String         @unique
  invitedByUserId String
  invitedBy       EcoUser        @relation("TaskAssigneeInviteSentBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  workspaceId     String
  workspace       EcoWorkspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /// PENDING | ACCEPTED | REVOKED
  status          String         @default("PENDING")
  createdAt       DateTime       @default(now())
  acceptedAt      DateTime?
  acceptedUserId  String?

  @@unique([itemId, email])
  @@index([token])
  @@index([workspaceId])
  @@map("TaskAssigneeInvite")
  @@schema("public")
}

model EcoUser {
  id            String             @id @default(uuid())
  email         String             @unique
  name          String?
  avatarUrl     String?
  status        String?            @default("Active")
  notifications  EcoNotification[]
  memberships    EcoMember[]
  boardsCreated  EcoBoard[]         @relation("BoardCreatedBy")
  itemsCreated   EcoItem[]          @relation("ItemCreatedBy")
  auditEntries   EcoTaskAuditLog[]
  emailsSent     EcoEmail[]         @relation("EmailsSent")
  emailsReceived EcoEmail[]         @relation("EmailsReceived")
  chatMemberships EcoChatMember[]
  chatMessagesSent EcoChatMessage[]
  taskAssigneeInvitesSent EcoTaskAssigneeInvite[] @relation("TaskAssigneeInviteSentBy")
  createdAt      DateTime           @default(now())

  @@map("User")
  @@schema("public")
}

model EcoTaskAuditLog {
  id          String   @id @default(uuid())
  itemId      String
  item        EcoItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  actorUserId String?
  actor       EcoUser? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  fieldKey    String
  oldValue    Json?
  newValue    Json?
  createdAt   DateTime @default(now())

  @@index([itemId])
  @@map("TaskAuditLog")
  @@schema("public")
}

model EcoNotification {
  id        String   @id @default(uuid())
  userId    String
  user      EcoUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String?
  link      String?
  createdAt DateTime @default(now())

  @@map("Notification")
  @@schema("public")
}

model EcoEmail {
  id          String   @id @default(uuid())
  senderId    String
  sender      EcoUser  @relation("EmailsSent", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   EcoUser  @relation("EmailsReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  subject     String
  content     String   @default("")
  read        Boolean  @default(false)
  starred     Boolean  @default(false)
  label       String?
  isDraft     Boolean  @default(false)
  isSent      Boolean  @default(false)
  isStarred   Boolean  @default(false)
  isSpam      Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  /// Hide from main inbox (per-message in this schema; no separate thread model).
  muted       Boolean  @default(false)
  cc          String?
  bcc         String?
  attachments Json     @default("[]")
  createdAt   DateTime @default(now())

  @@index([recipientId])
  @@index([senderId])
  @@map("Email")
  @@schema("public")
}

model EcoMember {
  id          String       @id @default(uuid())
  userId      String
  user        EcoUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   EcoWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        String       @default("MEMBER")
  createdAt   DateTime     @default(now())

  @@unique([userId, workspaceId])
  @@map("Member")
  @@schema("public")
}

/// Group chat thread (members + messages). Names map to UI "chat" list rows.
model EcoChatThread {
  id        String    @id @default(uuid())
  name      String
  avatarUrl String?
  ecoItemId String?
  ecoItem   EcoItem?  @relation(fields: [ecoItemId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  members   EcoChatMember[]
  messages  EcoChatMessage[]

  @@index([ecoItemId])
  @@map("ChatThread")
  @@schema("public")
}

model EcoChatMember {
  id         String        @id @default(uuid())
  threadId   String
  thread     EcoChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId     String
  user       EcoUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime?
  joinedAt   DateTime      @default(now())
  muted      Boolean       @default(false)
  blocked    Boolean       @default(false)

  @@unique([threadId, userId])
  @@index([userId])
  @@map("ChatMember")
  @@schema("public")
}

model EcoChatMessage {
  id          String        @id @default(uuid())
  threadId    String
  thread      EcoChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId    String
  sender      EcoUser       @relation(fields: [senderId], references: [id], onDelete: Cascade)
  text        String        @default("")
  attachments Json          @default("[]")
  createdAt   DateTime      @default(now())
  editedAt    DateTime?
  deletedAt   DateTime?

  replyToMessageId String?
  replyTo          EcoChatMessage?  @relation("MessageReply", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies          EcoChatMessage[] @relation("MessageReply")

  forwardedFromMessageId String?
  forwardedFrom          EcoChatMessage?  @relation("MessageForward", fields: [forwardedFromMessageId], references: [id], onDelete: SetNull)
  forwards               EcoChatMessage[] @relation("MessageForward")

  @@index([threadId])
  @@index([replyToMessageId])
  @@index([forwardedFromMessageId])
  @@map("ChatMessage")
  @@schema("public")
}
