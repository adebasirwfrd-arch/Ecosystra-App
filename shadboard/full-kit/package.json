{
  "name": "shadboard-nextjs-full-kit",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "description": "Ecosystra web app",
  "scripts": {
    "dev": "next dev",
    "dev:3002": "next dev -p 3002",
    "dev:3003": "next dev -p 3003",
    "dev:3003:turbo": "next dev --turbopack -p 3003",
    "dev:turbo": "next dev --turbopack",
    "dev:clean": "rm -rf .next",
    "dev:fresh": "pnpm run dev:clean && next dev",
    "build": "prisma generate && next build",
    "db:generate": "prisma generate",
    "start": "next start",
    "start:3002": "next start -p 3002",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --ignore-path .gitignore --write .",
    "migrate": "dotenv -e .env.local -- prisma migrate dev",
    "migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:migrate-from-sqlite": "dotenv -e .env.local -- node scripts/migrate-sqlite-auth.cjs",
    "db:seed-page-content": "pnpm exec dotenv -e .env.local -- tsx scripts/seed-shadboard-page-content.ts",
    "postinstall": "prisma generate",
    "verify:ecosystra-contrast": "node scripts/verify-ecosystra-contrast.mjs",
    "perf:explain-board": "dotenv -e .env.local -- tsx scripts/ecosystra-explain-board-load.ts",
    "db:verify-indexing": "dotenv -e .env.local -- prisma db execute --file prisma/sql/verify-ecosystra-advanced-indexing.sql"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.19.0",
