{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "pnpm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/due-date-reminders",
      "schedule": "0 7 * * *"
    }
  ]
}
