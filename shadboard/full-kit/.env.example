# Browser: log every GraphQL round-trip + `window.__ecosystraPerf` (dump after manual QA). Restart dev after change.
# NEXT_PUBLIC_ECOSYSTRA_PERF_LOG=true

# Must match the port you run `next dev` on (e.g. `pnpm dev:3002` → 3002).
BASE_URL=http://localhost:3002
API_URL=http://localhost:3002/api

# --- Production (Vercel) — Ecosystra URLs & due-date cron ---
# Set **one** of these (same value is fine for both). Either works for board links:
#   https://ecosystra-app.vercel.app
#   https://ecosystra-app.vercel.app/en/apps/ecosystra
# APP_BASE_URL=https://ecosystra-app.vercel.app/en/apps/ecosystra
# NEXT_PUBLIC_APP_URL=https://ecosystra-app.vercel.app/en/apps/ecosystra
# Brevo (due reminders + assignee mail): BREVO_API_KEY, BREVO_SENDER_EMAIL, BREVO_SENDER_NAME
# Cron: `vercel.json` schedules `/api/cron/due-date-reminders`. In Vercel → Settings → Environment Variables add:
#   CRON_SECRET=<random>  (optional if you only rely on Vercel Cron’s x-vercel-cron header)
# Manual: curl -H "Authorization: Bearer $CRON_SECRET" "https://ecosystra-app.vercel.app/api/cron/due-date-reminders"

# --- Supabase Postgres (Prisma) ---
# `prisma db push` / `migrate` use **DATABASE_URL** from `.env` (copy vars into `.env` for CLI, or use `dotenv -e .env.local`).
#
# **A — Direct (best latency when it works)**  
# DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
#
# **B — Transaction pooler (serverless / when :5432 is unreachable)**  
# Dashboard → Connect → ORM: Prisma. Port **6543**, host `aws-0-REGION.pooler.supabase.com`.  
# `src/lib/prisma.ts` appends `connection_limit=1` if missing. Example:
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
#
# **C — Runtime prefers direct, CLI can stay on pooler**  
# Set DATABASE_URL to pooler for migrations if needed, and set DIRECT_URL to direct `db.*:5432` for the app (omit PRISMA_USE_POOLER).
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
# If direct is unreachable from your machine, force pooler for the Next.js Prisma client:
# PRISMA_USE_POOLER=true
# Copy this file to `.env.local` (single source of truth). Prisma CLI does not load
# `.env.local` by default — use `pnpm db:push`, `pnpm migrate`, or `pnpm db:studio`.
# After `db:push`, seed page JSON (email/chat/calendar): `pnpm db:seed-page-content`
# Must match the origin you open in the browser (scheme + host + port). NextAuth builds
# Google redirect_uri as: {NEXTAUTH_URL}/api/auth/callback/google
# Middleware uses NEXTAUTH_SECRET to read the JWT — keep it set or auth checks always fail.
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=your_nextauth_secret_here
# Optional: set NEXTAUTH_DEBUG=true only when debugging NextAuth (otherwise noisy in dev).

# Google sign-in (optional). In Google Cloud Console → APIs & Services → Credentials →
# your OAuth 2.0 Client ID → add BOTH:
#   Authorized JavaScript origins: http://localhost:PORT  (same PORT as NEXTAUTH_URL)
#   Authorized redirect URIs:      http://localhost:PORT/api/auth/callback/google
# If you change dev port, update Console entries or set NEXTAUTH_URL to match.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Google Drive (board “Files” column uploads; server-side OAuth refresh token) ---
# Create a **Desktop** OAuth client in Google Cloud Console, enable Drive API, then obtain
# a refresh token for the account that should own uploaded files (workspace or service flow).
# Never commit secrets. If a client_secret was ever pasted in chat/email, rotate it in Console.
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
# GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3002
# GOOGLE_DRIVE_REFRESH_TOKEN=
# GOOGLE_DRIVE_ROOT_FOLDER_ID=   # parent folder id (Ecosystra root); uploads go Root / Group / Task
# Example folder id from a shared Drive link `.../folders/FOLDER_ID/...`:
# GOOGLE_DRIVE_ROOT_FOLDER_ID=1KRSTltt9GqCVUuXREAPnv4NRFTIiuh-x

# Google Picker (browser): create an API key with "Google Picker API" enabled; restrict by HTTP referrer.
# NEXT_PUBLIC_GOOGLE_PICKER_API_KEY=
# Optional: set to "true" so each uploaded file gets reader permission for "anyone with link"
# (improves iframe preview; only enable if your security model allows it).
# GOOGLE_DRIVE_LINK_SHARE_ANYONE=false

# Home redirect: use paths without :lang here; next.config rewrites to /:lang/...
# Use an /apps/* path (default below). Legacy template home values map to Ecosystra.
HOME_PATHNAME=/apps/ecosystra
NEXT_PUBLIC_HOME_PATHNAME=/apps/ecosystra

# Ecosystra embedded app — Apollo client (`EcosystraProviders`). Defaults to same-origin `/api/graphql` in the browser when unset.
# Do not set a production HTTPS URL here while running `pnpm dev` on localhost: cross-origin + credentials: "include" causes "Failed to fetch".
# Optional: point at a standalone GraphQL server during local API work.
# NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

# Supabase Realtime (WebRTC signaling for /apps/chat voice & video). Same project as DATABASE_URL.
# Dashboard → Project Settings → API: Project URL + anon public key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: chat attachment uploads to Supabase Storage (Dashboard → Settings → API → service_role).
# Create a public bucket named `chat-attachments` (Storage → New bucket → Public).
# Never commit this key or put it in NEXT_PUBLIC_*.
# SUPABASE_SERVICE_ROLE_KEY=

# Optional WebRTC TURN (only if STUN is not enough). Example: Metered.ca free tier.
# NEXT_PUBLIC_WEBRTC_TURN_URL=turn:global.turn.metered.live:3478
# NEXT_PUBLIC_WEBRTC_TURN_USER=...
# NEXT_PUBLIC_WEBRTC_TURN_PASS=...
# Or JSON array of RTCIceServer objects:
# NEXT_PUBLIC_WEBRTC_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"}]

# Client / boundary errors → POST /api/error-logs → logs/app-errors.log (JSON lines).
# In NODE_ENV=development the server also prints each entry to the terminal (console.error).
