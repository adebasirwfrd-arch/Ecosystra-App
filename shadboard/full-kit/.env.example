# Must match the port you run `next dev` on (e.g. `pnpm dev:3002` → 3002).
BASE_URL=http://localhost:3002
API_URL=http://localhost:3002/api

# Supabase Postgres — `prisma db push` / CLI uses **DATABASE_URL** only (use pooler :6543 if direct DB is unreachable).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Optional — direct host `db.<PROJECT_REF>.supabase.co:5432` for the **Next.js app** runtime (`src/lib/prisma.ts`).
# Not used by Prisma schema anymore. If your laptop cannot reach :5432, omit this and set PRISMA_USE_POOLER=true.
# DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"
# PRISMA_USE_POOLER=true
# Copy this file to `.env.local` (single source of truth). Prisma CLI does not load
# `.env.local` by default — use `pnpm db:push`, `pnpm migrate`, or `pnpm db:studio`.
# After `db:push`, seed Shadboard page JSON into Supabase: `pnpm db:seed-page-content`
# Optional — hydrate CRM tables from the same JSON (`modules.crm`) for `/dashboards/crm` + `/apps/sales-management`: `pnpm db:seed-crm`

# Must match the origin you open in the browser (scheme + host + port). NextAuth builds
# Google redirect_uri as: {NEXTAUTH_URL}/api/auth/callback/google
# Middleware uses NEXTAUTH_SECRET to read the JWT — keep it set or auth checks always fail.
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=your_nextauth_secret_here

# Google sign-in (optional). In Google Cloud Console → APIs & Services → Credentials →
# your OAuth 2.0 Client ID → add BOTH:
#   Authorized JavaScript origins: http://localhost:PORT  (same PORT as NEXTAUTH_URL)
#   Authorized redirect URIs:      http://localhost:PORT/api/auth/callback/google
# If you change dev port, update Console entries or set NEXTAUTH_URL to match.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Home redirect: use paths without :lang here; next.config rewrites to /:lang/...
HOME_PATHNAME=/dashboards/analytics
NEXT_PUBLIC_HOME_PATHNAME=/dashboards/analytics

# Ecosystra embedded app — Apollo client (`EcosystraProviders`). Defaults to same-origin `/api/graphql` in the browser when unset.
# Do not set a production HTTPS URL here while running `pnpm dev` on localhost: cross-origin + credentials: "include" causes "Failed to fetch".
# Optional: point at a standalone GraphQL server during local API work.
# NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

# Supabase Realtime (WebRTC signaling for /apps/chat voice & video). Same project as DATABASE_URL.
# Dashboard → Project Settings → API: Project URL + anon public key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: chat attachment uploads to Supabase Storage (Dashboard → Settings → API → service_role).
# Create a public bucket named `chat-attachments` (Storage → New bucket → Public).
# Never commit this key or put it in NEXT_PUBLIC_*.
# SUPABASE_SERVICE_ROLE_KEY=

# Optional WebRTC TURN (only if STUN is not enough). Example: Metered.ca free tier.
# NEXT_PUBLIC_WEBRTC_TURN_URL=turn:global.turn.metered.live:3478
# NEXT_PUBLIC_WEBRTC_TURN_USER=...
# NEXT_PUBLIC_WEBRTC_TURN_PASS=...
# Or JSON array of RTCIceServer objects:
# NEXT_PUBLIC_WEBRTC_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"}]

# Client / boundary errors → POST /api/error-logs → logs/app-errors.log (JSON lines).
# In NODE_ENV=development the server also prints each entry to the terminal (console.error).
